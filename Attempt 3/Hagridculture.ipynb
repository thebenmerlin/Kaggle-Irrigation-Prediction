    "# ============================================================\n",
    "# THRESHOLD OPTIMIZATION (Optional Post-processing)\n",
    "# ============================================================\n",
    "print(\"\\n🔍 Optimizing prediction thresholds...\")\n",
    "print(\"  (Skip this if you want quick results - takes ~30-60 sec)\")\n",
    "\n",
    "from scipy.optimize import minimize\n",
    "import time\n",
    "\n",
    "def optimize_thresholds(probs, y_true, time_limit=90):\n",
    "    \"\"\"Optimize thresholds for each class with time limit\"\"\"\n",
    "    \n",
    "    def objective(thresholds):\n",
    "        preds = np.ones(len(probs), dtype=int) * -1\n",
    "        \n",
    "        for i in range(probs.shape[1]):\n",
    "            if i < len(thresholds):\n",
    "                mask = probs[:, i] > thresholds[i]\n",
    "                preds[mask] = i\n",
    "        \n",
    "        # Handle unassigned\n",
    "        unassigned = preds == -1\n",
    "        if unassigned.any():\n",
    "            preds[unassigned] = np.argmax(probs[unassigned], axis=1)\n",
    "        \n",
    "        return -balanced_accuracy_score(y_true, preds)\n",
    "    \n",
    "    best_score = 0\n",
    "    best_thresholds = None\n",
    "    start_time = time.time()\n",
    "    \n",
    "    # Try multiple starting points with time limit\n",
    "    for attempt in range(10):\n",
    "        if time.time() - start_time > time_limit:\n",
    "            print(f\"  ⏱️  Time limit reached ({time_limit}s), stopping optimization\")\n",
    "            break\n",
    "        \n",
    "        x0 = np.random.uniform(0.2, 0.5, size=probs.shape[1]-1)\n",
    "        try:\n",
    "            result = minimize(objective, x0, method='Nelder-Mead', \n",
    "                            options={'maxiter': 1000})\n",
    "            if -result.fun > best_score:\n",
    "                best_score = -result.fun\n",
    "                best_thresholds = result.x\n",
    "        except:\n",
    "            continue\n",
    "    \n",
    "    return best_thresholds, best_score\n",
    "\n",
    "# Optimize on best ensemble\n",
    "thresholds, opt_score = optimize_thresholds(best_ensemble, y, time_limit=90)\n",
    "\n",
    "if thresholds is not None and opt_score > best_score:\n",
    "    print(f\"  ✓ Optimized score: {opt_score:.6f} (improved by {opt_score - best_score:.6f})\")\n",
    "    print(f\"  Thresholds: {thresholds}\")\n",
    "    \n",
    "    # Apply to test predictions\n",
    "    test_ensemble = (test_xgb + test_lgb + test_cat) / 3 if best_name == 'XGB+LGB+CAT' else \\\n",
    "                   test_xgb if best_name == 'XGB' else \\\n",
    "                   test_lgb if best_name == 'LGB' else \\\n",
    "                   test_cat if best_name == 'CAT' else \\\n",
    "                   (test_xgb + test_lgb) / 2 if best_name == 'XGB+LGB' else \\\n",
    "                   (test_xgb + test_cat) / 2 if best_name == 'XGB+CAT' else \\\n",
    "                   (test_lgb + test_cat) / 2\n",
    "else:\n",
    "    print(f\"  ⚠️  Optimization didn't improve (keeping base score: {best_score:.6f})\")\n",
    "    thresholds = None\n",
    "    test_ensemble = (test_xgb + test_lgb + test_cat) / 3 if best_name == 'XGB+LGB+CAT' else \\\n",
    "                   (test_xgb + test_lgb) / 2 if best_name == 'XGB+LGB' else \\\n",
    "                   (test_xgb + test_cat) / 2 if best_name == 'XGB+CAT' else \\\n",
    "                   (test_lgb + test_cat) / 2\n",
    "\n",
    "# Clean up\n",
    "del optimize_thresholds\n",
    "gc.collect()"
   ]
